# ============================================
# 🤖 Telegram Hosting Bot — Environment Setup
# ============================================
# Koyeb / Railway / Render pe yeh variables
# Environment mein add karo.
#
# Local use ke liye:
#   1. Neeche se copy karo
#   2. Apni values bharo
#   3. Terminal mein paste karo ya .env file banao
# ============================================

export BOT_TOKEN="your_bot_token_here"

export ADMIN_ID_1="111111111"
export ADMIN_ID_2="222222222"
export ADMIN_ID_3="333333333"

export OWNER_ID="your_owner_id"

export GROUP_ID="-100xxxxxxxxx"

export GITHUB_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxxxx"
export GITHUB_REPO="username/reponame"

export PORT="8080"
export WEBHOOK_URL=""

export REQUIRED_CHANNEL="https://t.me/yourchannel"
export REQUIRED_CHANNEL_ID="-100xxxxxxxxx"
